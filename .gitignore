# ═══════════════════════════════════════════
# GoRodadero — .gitignore
# ═══════════════════════════════════════════

# ─── CREDENCIALES (NUNCA subir) ───
.env
.env.local
.env.production
.env.*.local

# ─── Dependencias ───
node_modules/

# ─── Next.js build ───
.next/
out/

# ─── Prisma ───
prisma/*.db
prisma/*.db-journal

# ─── OS files ───
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo

# ─── Debug logs ───
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Vercel ───
.vercel/

# ─── TypeScript cache ───
*.tsbuildinfo
next-env.d.ts

# ─── Misc ───
*.log

# ─── ETL Backups (no subir al repo) ───
scripts/products_backup_*.json
scripts/etl_*.log
scripts/supabase_dump.json
